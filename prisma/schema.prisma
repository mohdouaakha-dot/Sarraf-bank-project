datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPPORT
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum Currency {
  DZD
  EUR
}

enum OrderStatus {
  LISTED
  MATCHED
  WAITING_FOR_DZD
  PROOF_UPLOADED
  SELLER_CONFIRMED
  EUR_RELEASED
  COMPLETED
  DISPUTED
  CANCELLED
}

model User {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  email           String    @unique
  passwordHash    String
  phoneNumber     String    @unique
  role            Role      @default(USER)

  trustScore      Int       @default(100)
  totalTrades     Int       @default(0)

  kycStatus       KycStatus @default(NOT_STARTED)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallets         Wallet[]
  kyc             KycVerification?
  paymentAccounts PaymentAccount[]
  offersCreated   Offer[]   @relation("SellerOffers")
  ordersAsBuyer   Order[]   @relation("BuyerOrders")
  ordersAsSeller  Order[]   @relation("SellerOrders")
  disputes        Dispute[]
  auditLogs       AuditLog[]
}

// Reference only. idDocumentStorageKey / selfieStorageKey point at files in
// encrypted object storage (or, for now, a local uploads folder while
// testing) — never store the raw document, extracted ID number, or
// biometric data directly on this row. provider/providerApplicantId stay
// null until you plug in a real KYC provider (Sumsub/Onfido/Veriff); until
// then, status starts PENDING and gets flipped manually by an admin.
model KycVerification {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  idDocumentStorageKey String?
  selfieStorageKey      String?

  provider            String?
  providerApplicantId  String?   @unique
  status              KycStatus @default(PENDING)
  reviewedAt          DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model PaymentAccount {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String
  currency        Currency
  encryptedValue  String
  maskedDisplay   String
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId])
}

model Wallet {
  id           String   @id @default(uuid())
  userId       String
  currency     Currency
  balanceCents Int      @default(0)
  lockedCents  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

model Offer {
  id             String   @id @default(uuid())
  userId         String
  side           String
  fromCurrency   Currency
  toCurrency     Currency
  rate           Int
  amountCents    Int
  minAmountCents Int
  maxAmountCents Int
  paymentMethod  String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user           User     @relation("SellerOffers", fields: [userId], references: [id])
  orders         Order[]
}

model Order {
  id           String      @id @default(uuid())
  offerId      String
  buyerId      String
  sellerId     String
  amountCents  Int
  fiatAmount   Int
  status       OrderStatus @default(LISTED)

  receiptStorageKey String?
  ocrVerified       Boolean @default(false)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  offer        Offer       @relation(fields: [offerId], references: [id])
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller       User        @relation("SellerOrders", fields: [sellerId], references: [id])
  disputes     Dispute[]
}

model Dispute {
  id          String   @id @default(uuid())
  orderId     String
  raisedById  String
  reason      String
  evidenceStorageKey String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id])
  raisedBy    User     @relation(fields: [raisedById], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
